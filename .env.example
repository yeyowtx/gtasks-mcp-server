# Google Tasks MCP Server Environment Variables

# Server Configuration
NODE_ENV=development
PORT=10000

# Google OAuth Credentials Path
# This should point to your .gtasks-server-credentials.json file
# For local development: leave empty (defaults to ./.gtasks-server-credentials.json)
# For Render deployment: set to /opt/render/project/src/.gtasks-server-credentials.json
GOOGLE_CREDENTIALS_PATH=

# For Render deployment, you'll need to:
# 1. Run authentication locally first: npm run auth
# 2. Upload .gtasks-server-credentials.json to Render as a secret file
# 3. Set GOOGLE_CREDENTIALS_PATH to the uploaded file path
